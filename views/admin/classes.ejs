<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/stylesheet/dashboard.css">
    <link rel="stylesheet" href="/stylesheet/menuToggle.css">
    <link rel="stylesheet" href="/stylesheet/overlay.css">
    <link rel="stylesheet" href="/stylesheet/table.css">
</head>
<body>
    <% if (action === "list"){%>
        <div class="dashboard">

    <!-- Sidebar -->
    <aside class="sidebar">
        <h2 class="logo">SchoolBase</h2>

        <nav>
            <a href="/admin">Dashboard</a>
            <a href="/admin/student">Students</a>
            <a href="/teachers">Teachers</a>
            <a href="/sessions">Academic Sessions</a>
            <a href="/classes" class="active">Classes</a>
            <a href="/subjects">Subjects</a>
            <a href="/fees">Fee Management</a>
            <a href="/adminResult">Results</a>
            <a href="/settings">Settings</a>
        </nav>

        <a href="/logout" class="logout">Logout</a>
    </aside>

    <!-- Main Content -->
    <main class="content">
        <button class="menu-btn" onclick="toggleMenu()">☰</button>

        <header class="topbar">
            <h3>Class</h3>
            <h1>Class Management</h1>
            <span class="date" id="todayDate"></span>
        </header>

        <div id="overlay" onclick="closeAll()"></div>

        <!-- Action Bar -->
        <section class="actions">
            <button onclick="openModal('classModal')">➕ Add Class</button>
        </section>

        <!-- Student Table -->
        <section class="table-section">
  <div class="table-header">
    <h2>Class</h2>

    <input
      type="text"
      id="searchInput"
      placeholder="Search student..."
      onkeyup="searchTable()"
    />
  </div>

  <div class="table-wrapper">
  <table id="studentTable">
    <thead>
      <tr>
        <th onclick="sortTable(1)">Class ⬍</th>
        <th>No. of Stud.</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
  <% listClass.forEach((classItem) => { %>
    <tr>
      <td><%= classItem.className %></td>

      <td>
        <%= classItem.studentCount %>
      </td>

      <td class="actions">
        <a href="/edit/class/<%= classItem._id %>">
          <button class="btn edit">Edit</button>
        </a>
        <a href="/classinfo/<%= classItem._id %>">
          <button class="btn info">Info</button>
        </a>

        <form action="/classes/delete/<%= classItem._id %>" method="post" style="display:inline;">
  <button
    class="btn delete"
    onclick="return confirm('Are you sure you want to delete this class?')">
    Delete
  </button>
</form>

      </td>
    </tr>
  <% }) %>
</tbody>

  </table>
    </div>

  <div id="pagination"></div>
</section>


    </main>
</div>

<!-- ================= ADD CLASS MODAL ================= -->
<div class="modal" id="classModal">
    <form action="/admin/addClass" method="post">
        <h2>Add Class</h2>
        <input type="hidden" name="schoolID" value="<%= showUser._id %>">
        <input type="text" name="className" placeholder="e.g. JSS 1" required>
        <button>Submit</button>
        <span class="close" onclick="closeAll()">×</span>
    </form>
</div>

<!-- ================= EDIT STUDENT MODAL ================= -->

    <%}else{%>
        unauthorized user.
    <%}%>
    <script src="/scriptFolder/menuToggle.js"></script>
    <script src="/scriptFolder/editAdminStudent.js"></script>
    <script src="/scriptFolder/openModal.js"></script>
    <script src="/scriptFolder/searchTable.js"></script>
    <script src="/scriptFolder/showDate.js"></script>
</html>