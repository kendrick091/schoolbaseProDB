<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/stylesheet/dashboard.css">
    <link rel="stylesheet" href="/stylesheet/session.css">
    <link rel="stylesheet" href="/stylesheet/table.css">
    <link rel="stylesheet" href="/stylesheet/form.css">
    <link rel="stylesheet" href="/stylesheet/menuToggle.css">
    <link rel="stylesheet" href="/stylesheet/overlay.css">
</head>
<body>
     <div class="dashboard">

  <!-- Sidebar (DO NOT CHANGE) -->
  <aside class="sidebar">
    <h2 class="logo">SchoolBase</h2>

    <nav>
      <a href="/admin">Dashboard</a>
      <a href="/admin/student">Students</a>
      <a href="/teachers">Teachers</a>
      <a href="/sessions" class="active">Academic Sessions</a>
      <a href="/classes">Classes</a>
      <a href="/subjects">Subjects</a>
      <a href="/fees">Fee Management</a>
      <a href="/adminResult">Results</a>
      <a href="/settings">Settings</a>
    </nav>

    <a href="/logout" class="logout">Logout</a>
  </aside>

  <!-- Main Content -->
  <main class="content">
    <button class="menu-btn" onclick="toggleMenu()">☰</button>

    <header class="topbar">
      <h1>Academic Sessions</h1>
      <span class="date" id="todayDate"></span>
    </header>

    <!-- Add session button -->
    <div class="table-actions">
      <button class="btn primary" onclick="openModal('sessionModal')">
        + Add New Session
      </button>
    </div>

    <div id="overlay" onclick="closeAll()"></div>

    <!-- Sessions Table -->
    <div class="table-wrapper">
      <table class="styled-table">
        <thead>
          <tr>
            <th>Session Name</th>
            <th>1st term vacate</th>
            <th>2nd term resume</th>
            <th>2nd term vacate</th>
            <th>3rd term resume</th>
            <th>3rd term vacate</th>
            <th>next session resume</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>

        <tbody>
          <% sessions.forEach(session => { %>
            <tr class="<%= session.isActive ? 'row-active' : '' %>">
              <td><%= session.academicSession %></td>
              <td><%= session.firstTermVacate %></td>
              <td><%= session.secondTermResume %></td>
              <td><%= session.secondTermVacate %></td>
              <td><%= session.thirdTermResume %></td>
              <td><%= session.thirdTermVacate %></td>
              <td><%= session.firstTermResume %></td>

              <td>
                <% if (session.isActive) { %>
                  <span class="status active">Active</span>
                <% } else { %>
                  <span class="status inactive">Inactive</span>
                <% } %>
              </td>

              <td>
                <% if (session.isActive) { %>
                  <button class="btn active-btn" disabled>
                    Active Session
                  </button>
                <% } else { %>
                  <form action="/sessions/activate/<%= session._id %>" method="post">
                    <button class="btn activate-btn">
                      Activate
                    </button>
                  </form>
                <% } %>
                <a href="/edit/session/<%= session._id %>">
                  <button style="background: rgb(5, 26, 58);
                padding: 10px 20px; color:white; margin: 3px; cursor: pointer;">
                  Edit
                </button>
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <!-- Add Session -->
<div class="modal" id="sessionModal">
    <form action="/admin/addSession" method="post">
        <h2>Add Academic Session</h2>
        <input type="hidden" name="schoolID" value="<%= showUser._id %>">
        <input type="text" name="academicSession" placeholder="e.g. 2024 / 2025" required>
        <button>Submit</button>
        <span class="close" onclick="closeAll()">×</span>
    </form>
</div>

  </main>
</div>

    <script src="/scriptFolder/showDate.js"></script>
    <script src="/scriptFolder/menuToggle.js"></script>
    <script src="/scriptFolder/openModal.js"></script>
</body>
</html>